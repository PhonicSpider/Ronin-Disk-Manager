<mah:MetroWindow x:Class="RoninDiskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:vm="clr-namespace:RoninDiskManager.ViewModels"
        xmlns:conv="clr-namespace:RoninDiskManager.Converters"
        xmlns:ctrl="clr-namespace:RoninDiskManager.Controls"
        Title="Ronin Disk Manager"
        Icon="Assets/icon.ico"
        Height="820" Width="1280"
        MinHeight="620" MinWidth="960"
        TitleCharacterCasing="Normal"
        WindowStartupLocation="CenterScreen"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <mah:MetroWindow.Resources>
        <conv:NullToVisibilityConverter          x:Key="NullToVis"/>
        <conv:InverseBoolConverter               x:Key="InvBool"/>
        <BooleanToVisibilityConverter            x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter   x:Key="InvBoolToVis"/>

        <!-- ── Ronin brand colours ─────────────────────────────────────────── -->
        <SolidColorBrush x:Key="Ronin.Orange"       Color="#E06020"/>
        <SolidColorBrush x:Key="Ronin.OrangeDim"    Color="#7A3010"/>
        <SolidColorBrush x:Key="Ronin.Cyan"         Color="#00C0D8"/>
        <SolidColorBrush x:Key="Ronin.CyanBright"   Color="#00D8F0"/>
        <SolidColorBrush x:Key="Ronin.CyanDim"      Color="#2A7A8A"/>
        <SolidColorBrush x:Key="Ronin.Surface"      Color="#0E0E0E"/>
        <SolidColorBrush x:Key="Ronin.PanelBg"      Color="#0B0507"/>
        <SolidColorBrush x:Key="Ronin.Border"       Color="#3A0A0A"/>
        <SolidColorBrush x:Key="Ronin.BorderSubtle" Color="#1A0606"/>
        <SolidColorBrush x:Key="Ronin.BorderHover"  Color="#6A1010"/>
        <SolidColorBrush x:Key="Ronin.TextDim"      Color="#505050"/>
        <SolidColorBrush x:Key="Ronin.TextMid"      Color="#909090"/>
        <SolidColorBrush x:Key="Ronin.TextBright"   Color="#CFCFCF"/>
        <SolidColorBrush x:Key="Ronin.ConsoleBg"    Color="#060606"/>
        <SolidColorBrush x:Key="Ronin.SelectBg"     Color="#1A0808"/>
        <SolidColorBrush x:Key="Ronin.HoverBg"      Color="#131313"/>

        <!-- ── Section header label ───────────────────────────────────────── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="9"/>
            <Setter Property="FontWeight"    Value="Bold"/>
            <Setter Property="Foreground"    Value="{StaticResource Ronin.Orange}"/>
            <Setter Property="Margin"        Value="0,12,0,5"/>
        </Style>

        <!-- ── Compact flag checkbox ──────────────────────────────────────── -->
        <Style x:Key="FlagCheck" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>

        <!-- ── Tree item hover + selection style ─────────────────────────── -->
        <Style x:Key="RoninTreeItem" TargetType="TreeViewItem"
               BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="IsExpanded"     Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected"     Value="{Binding IsSelected,  Mode=TwoWay}"/>
            <Setter Property="Padding"        Value="2,1"/>
            <Setter Property="Foreground"     Value="#C8C8C8"/>
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="BorderBrush"    Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Ronin.HoverBg}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"   Value="{StaticResource Ronin.SelectBg}"/>
                    <Setter Property="Foreground"   Value="{StaticResource Ronin.CyanBright}"/>
                    <Setter Property="BorderBrush"  Value="{StaticResource Ronin.Orange}"/>
                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Rich tooltip style ─────────────────────────────────────────── -->
        <Style x:Key="RoninTooltip" TargetType="ToolTip">
            <Setter Property="Background"       Value="#0F0F0F"/>
            <Setter Property="Foreground"       Value="#C8C8C8"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Ronin.Border}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,7"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="HasDropShadow"    Value="True"/>
        </Style>

        <!-- ── Context menu style ─────────────────────────────────────────── -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="#111111"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Ronin.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="0,3"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground"  Value="#C8C8C8"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="10,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource Ronin.SelectBg}"/>
                    <Setter Property="Foreground" Value="{StaticResource Ronin.CyanBright}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource Ronin.TextDim}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource Ronin.Border}"/>
            <Setter Property="Margin"     Value="6,3"/>
        </Style>

    </mah:MetroWindow.Resources>

    <Grid Background="#0A0A0A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- scan bar         -->
            <RowDefinition Height="*"/>      <!-- main content     -->
            <RowDefinition Height="Auto"/>   <!-- status bar       -->
            <RowDefinition Height="5"/>      <!-- splitter         -->
            <RowDefinition Height="185" MinHeight="60"/>  <!-- console -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════ SCAN BAR -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource Ronin.Border}"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#111111" Offset="0"/>
                    <GradientStop Color="#0A0A0A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="12,8,12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Command="{Binding ScanCommand}"
                            IsEnabled="{Binding IsOperationRunning, Converter={StaticResource InvBool}}"
                            Content="▶   Scan"
                            Width="90" Margin="6,0,0,0"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding PinCurrentPathCommand}"
                            Content="📌" Width="34" Margin="4,0,0,0"
                            ToolTip="Pin the current path for one-click rescans"/>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding SearchAllDrivesCommand}"
                            IsEnabled="{Binding IsOperationRunning, Converter={StaticResource InvBool}}"
                            Content="🔍  Search"
                            Width="100" Margin="4,0,0,0"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding CancelScanCommand}"
                            IsEnabled="{Binding IsOperationRunning}"
                            Content="✖" Width="34" Margin="4,0,0,0"
                            ToolTip="Cancel current operation"/>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding BrowseScanPathCommand}"
                            Content="…" Width="34" Margin="4,0,0,0"
                            ToolTip="Browse for a folder or drive"/>
                    <TextBlock DockPanel.Dock="Left"
                               Text="📂" FontSize="15"
                               Foreground="{StaticResource Ronin.Orange}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="InputBox"
                             Text="{Binding InputQuery, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" VerticalContentAlignment="Center"
                             Background="#141414" Foreground="#D0D0D0"
                             BorderBrush="{StaticResource Ronin.Border}"
                             CaretBrush="{StaticResource Ronin.Cyan}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ScanCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding StatusText}"
                           FontSize="11" Margin="0,4,0,0"
                           Foreground="{StaticResource Ronin.CyanDim}"/>

                <!-- Pinned paths -->
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding PinnedPaths}"
                              Margin="0,6,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#141414"
                                    BorderBrush="{StaticResource Ronin.Border}"
                                    BorderThickness="1" CornerRadius="3"
                                    Margin="0,0,6,4" Padding="2,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{Binding}"
                                            Command="{Binding DataContext.ScanPinnedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource Ronin.CyanBright}"
                                            FontSize="11" Padding="6,2" Cursor="Hand"
                                            ToolTip="Scan this pinned path"/>
                                    <Button Content="✖"
                                            Command="{Binding DataContext.UnpinPathCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource Ronin.TextDim}"
                                            FontSize="10" Padding="4,2" Cursor="Hand"
                                            ToolTip="Unpin"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ═════════════════════════════ TREE VIEW + ACTION PANEL SPLIT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="340" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ────────────────────── TREE / TREEMAP / SEARCH RESULTS -->
            <!-- Pass VM as Tag so ContextMenu can bind to it via PlacementTarget -->
            <TabControl Grid.Column="0"
                        x:Name="LeftTabs"
                        Background="#080808"
                        BorderThickness="0"
                        TabStripPlacement="Top"
                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

                <!-- Keep all tab headers on a single row (no wrapping to a second line) -->
                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>

                <!-- Host the header strip in a horizontal scroller so it scrolls,
                     rather than wraps, when the window is too narrow for all tabs. -->
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Focusable="False"
                                          Padding="0">
                                <ItemsPresenter/>
                            </ScrollViewer>
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- ══════════════════════════════════════ TAB: TREE -->
                <TabItem Header="Tree">
                    <Grid Background="#080808">

                        <!-- Tree view -->
                        <TreeView x:Name="DiskTree"
                                  ItemsSource="{Binding TreeRoots}"
                                  SelectedItemChanged="DiskTree_SelectedItemChanged"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  Background="#080808"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsShowingSearchResults, Converter={StaticResource InvBoolToVis}}"
                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

                            <TreeView.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
                            </TreeView.InputBindings>

                            <TreeView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </TreeView.ItemsPanel>

                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource RoninTreeItem}"/>
                            </TreeView.ItemContainerStyle>

                            <!-- Context menu on tree — binds through Tag to main VM -->
                            <TreeView.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="🗂  Open in Explorer"
                                              Command="{Binding OpenInExplorerCommand}"
                                              InputGestureText="Ctrl+E"/>
                                    <MenuItem Header="📋  Copy Path"
                                              Command="{Binding CopyPathCommand}"
                                              InputGestureText="Ctrl+Shift+C"/>
                                    <MenuItem Header="💻  Open Terminal Here"
                                              Command="{Binding OpenTerminalCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="📦  Move…"
                                              Command="{Binding SetMoveModeCommand}"/>
                                    <MenuItem Header="📑  Copy…"
                                              Command="{Binding SetCopyModeCommand}"/>
                                    <MenuItem Header="🗑  Delete…"
                                              Command="{Binding SetDeleteModeCommand}"/>
                                </ContextMenu>
                            </TreeView.ContextMenu>

                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type vm:DiskNodeViewModel}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,2,10,2">
                                        <StackPanel.ToolTip>
                                            <ToolTip Style="{StaticResource RoninTooltip}"
                                                     Content="{Binding ToolTipText}"/>
                                        </StackPanel.ToolTip>

                                        <!-- left accent line: orange for dirs, Light for files -->
                                        <Border Width="2" Margin="0,0,6,0" CornerRadius="1"
                                                VerticalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#909090"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Ronin.OrangeDim}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- icon -->
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="Segoe UI Emoji" FontSize="12"
                                                   Foreground="{StaticResource Ronin.Orange}"
                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>

                                        <!-- name + proportion bar stacked vertically -->
                                        <StackPanel MinWidth="90" VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12.5" Foreground="#DCDCDC"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <!-- proportion bar: fixed 80px track, BarWidth fill -->
                                            <Grid Margin="0,3,0,0" Height="2" Width="80"
                                                  HorizontalAlignment="Left">
                                                <Border Background="#1E1E1E" CornerRadius="1"/>
                                                <Border Background="{StaticResource Ronin.CyanBright}"
                                                        Width="{Binding BarWidth}"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="1"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- size value: Orange -->
                                        <TextBlock Text="{Binding SizeText}"
                                                   Width="62" TextAlignment="Right"
                                                   FontSize="13" FontFamily="Consolas"
                                                   Foreground="#E06020"
                                                   VerticalAlignment="Center"/>

                                        <!-- percentage: muted cyan -->
                                        <TextBlock Text="{Binding PctText}"
                                                   Width="44" TextAlignment="Right"
                                                   FontSize="12" FontFamily="Consolas"
                                                   Foreground="#486878"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>

                        <!-- Search results DataGrid -->
                        <DataGrid x:Name="SearchGrid"
                                  ItemsSource="{Binding SearchResults}"
                                  SelectedItem="{Binding SelectedSearchResult}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  Background="#080808"
                                  Foreground="#C8C8C8"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource Ronin.BorderSubtle}"
                                  RowBackground="#080808"
                                  AlternatingRowBackground="#0D0D0D"
                                  ColumnHeaderHeight="26"
                                  FontSize="12"
                                  SelectionMode="Single"
                                  Visibility="{Binding IsShowingSearchResults, Converter={StaticResource BoolToVis}}"
                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                            <DataGrid.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="🗂  Open in Explorer"
                                              Command="{Binding OpenInExplorerCommand}"/>
                                    <MenuItem Header="📋  Copy Path"
                                              Command="{Binding CopyPathCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="📦  Move…"
                                              Command="{Binding SetMoveModeCommand}"/>
                                    <MenuItem Header="📑  Copy…"
                                              Command="{Binding SetCopyModeCommand}"/>
                                    <MenuItem Header="🗑  Delete…"
                                              Command="{Binding SetDeleteModeCommand}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                                <DataGridTextColumn Header="Type"     Binding="{Binding FileType}" Width="80"/>
                                <DataGridTextColumn Header="Size"     Binding="{Binding SizeDisplay}" Width="70"/>
                                <DataGridTextColumn Header="Modified" Binding="{Binding DateModified, StringFormat='{}{0:yyyy-MM-dd}'}" Width="95"/>
                                <DataGridTextColumn Header="Path"     Binding="{Binding FullPath}"  Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </Grid>
                </TabItem>

                <!-- ══════════════════════════════════ TAB: TREEMAP -->
                <TabItem Header="Treemap">
                    <ctrl:TreemapControl
                        RootNode="{Binding TreemapRoot}"
                        SelectedDiskNode="{Binding TreemapSelectedNode, Mode=OneWayToSource}"/>
                </TabItem>

                <!-- ══════════════════════════════ TAB: LARGEST FILES -->
                <TabItem Header="Largest Files">
                    <Grid Background="#080808">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="8,6" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="Free-space target (GB):"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource Ronin.TextMid}" Margin="0,0,6,0"/>
                            <TextBox DockPanel.Dock="Left" Width="70"
                                     Text="{Binding FreeSpaceTargetGb, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#141414" Foreground="#D0D0D0"
                                     BorderBrush="{StaticResource Ronin.Border}"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Highlighted rows are the biggest files whose combined size reaches this target."/>
                            <TextBlock DockPanel.Dock="Left" Text="Highlighted rows together reach the target."
                                       VerticalAlignment="Center" FontSize="10"
                                       Foreground="{StaticResource Ronin.TextDim}" Margin="10,0,0,0"/>
                        </DockPanel>

                        <DataGrid Grid.Row="1" x:Name="LargestGrid"
                                  ItemsSource="{Binding LargestFiles}"
                                  SelectedItem="{Binding SelectedLargestFile}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  Background="#080808"
                                  Foreground="#C8C8C8"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource Ronin.BorderSubtle}"
                                  ColumnHeaderHeight="26"
                                  FontSize="12"
                                  SelectionMode="Single"
                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#080808"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WithinFreeSpaceTarget}" Value="True">
                                            <Setter Property="Background" Value="#0F2018"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="🗂  Open in Explorer" Command="{Binding OpenInExplorerCommand}"/>
                                    <MenuItem Header="📋  Copy Path" Command="{Binding CopyPathCommand}"/>
                                    <MenuItem Header="💻  Open Terminal Here" Command="{Binding OpenTerminalCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="📦  Move…" Command="{Binding SetMoveModeCommand}"/>
                                    <MenuItem Header="📑  Copy…" Command="{Binding SetCopyModeCommand}"/>
                                    <MenuItem Header="🗑  Delete…" Command="{Binding SetDeleteModeCommand}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"       Binding="{Binding Name}"        Width="*"/>
                                <DataGridTextColumn Header="Size"       Binding="{Binding SizeDisplay}"  Width="75"/>
                                <DataGridTextColumn Header="Cumulative" Binding="{Binding CumulativeDisplay}" Width="85"/>
                                <DataGridTextColumn Header="Modified"   Binding="{Binding DateModified, StringFormat='{}{0:yyyy-MM-dd}'}" Width="90"/>
                                <DataGridTextColumn Header="Path"       Binding="{Binding FullPath}"     Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ══════════════════════════════════ TAB: EXTENSIONS -->
                <TabItem Header="Extensions">
                    <DataGrid ItemsSource="{Binding ExtensionStats}"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              Background="#080808"
                              Foreground="#C8C8C8"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource Ronin.BorderSubtle}"
                              RowBackground="#080808"
                              AlternatingRowBackground="#0D0D0D"
                              ColumnHeaderHeight="26"
                              FontSize="12"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Extension"  Binding="{Binding Extension}"   Width="*"/>
                            <DataGridTextColumn Header="Files"      Binding="{Binding FileCount}"   Width="100"/>
                            <DataGridTextColumn Header="Total Size" Binding="{Binding SizeDisplay}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ══════════════════════════════ TAB: EMPTY FOLDERS -->
                <TabItem Header="Empty Folders">
                    <DataGrid x:Name="EmptyGrid"
                              ItemsSource="{Binding EmptyFolders}"
                              SelectedItem="{Binding SelectedEmptyFolder}"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              Background="#080808"
                              Foreground="#C8C8C8"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource Ronin.BorderSubtle}"
                              RowBackground="#080808"
                              AlternatingRowBackground="#0D0D0D"
                              ColumnHeaderHeight="26"
                              FontSize="12"
                              SelectionMode="Single"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="🗂  Open in Explorer" Command="{Binding OpenInExplorerCommand}"/>
                                <MenuItem Header="📋  Copy Path" Command="{Binding CopyPathCommand}"/>
                                <Separator/>
                                <MenuItem Header="🗑  Delete…" Command="{Binding SetDeleteModeCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folder" Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Path"   Binding="{Binding FullPath}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ══════════════════════════════════ TAB: DUPLICATES -->
                <TabItem Header="Duplicates">
                    <Grid Background="#080808">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="8,6" LastChildFill="True">
                            <Button DockPanel.Dock="Left"
                                    Content="🔍  Find Duplicates"
                                    Command="{Binding FindDuplicatesCommand}"
                                    IsEnabled="{Binding IsFindingDuplicates, Converter={StaticResource InvBool}}"
                                    FontSize="11" Height="26" Padding="8,0"/>
                            <Button DockPanel.Dock="Left"
                                    Content="✖"
                                    Command="{Binding CancelDuplicatesCommand}"
                                    IsEnabled="{Binding IsFindingDuplicates}"
                                    Width="30" Height="26" Margin="6,0,0,0"
                                    ToolTip="Cancel duplicate scan"/>
                            <TextBlock Text="{Binding DuplicateStatus}"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource Ronin.CyanDim}"
                                       Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                        </DockPanel>

                        <DataGrid Grid.Row="1" x:Name="DupGrid"
                                  ItemsSource="{Binding DuplicateFiles}"
                                  SelectedItem="{Binding SelectedDuplicate}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  Background="#080808"
                                  Foreground="#C8C8C8"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource Ronin.BorderSubtle}"
                                  RowBackground="#080808"
                                  AlternatingRowBackground="#0D0D0D"
                                  ColumnHeaderHeight="26"
                                  FontSize="12"
                                  SelectionMode="Single"
                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                            <DataGrid.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="🗂  Open in Explorer" Command="{Binding OpenInExplorerCommand}"/>
                                    <MenuItem Header="📋  Copy Path" Command="{Binding CopyPathCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="🗑  Delete…" Command="{Binding SetDeleteModeCommand}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}"       Width="*"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="80"/>
                                <DataGridTextColumn Header="Path" Binding="{Binding FullPath}"    Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- ──────────────────────────────────── COLUMN SPLITTER -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource Ronin.Border}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Background" Value="{StaticResource Ronin.Border}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Ronin.BorderHover}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- ─────────────────────────────────── ACTION PANEL -->
            <TabControl Grid.Column="2"
                        Background="{StaticResource Ronin.PanelBg}"
                        BorderThickness="0">

                <!-- ═══════════════════════════════════ TAB: ACTIONS -->
                <TabItem Header="Actions">
                    <Grid Background="{StaticResource Ronin.PanelBg}">

                        <!-- Placeholder when nothing selected -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding SelectedNode, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                            <TextBlock Text="📂"
                                       FontFamily="Segoe UI Emoji" FontSize="32"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource Ronin.OrangeDim}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Select an item to manage it."
                                       FontSize="13"
                                       Foreground="{StaticResource Ronin.TextDim}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Action panel -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding SelectedNode, Converter={StaticResource NullToVis}}">
                            <StackPanel Margin="14,10,14,14">

                                <!-- Selected item info -->
                                <TextBlock Text="SELECTED ITEM" Style="{StaticResource SectionLabel}" Margin="0,0,0,5"/>

                                <Border Background="#0D0D0D"
                                        BorderBrush="{StaticResource Ronin.BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="10,8"
                                        Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedNode.Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#E8E8E8"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SelectedNode.SizeDisplay}"
                                                   FontSize="12" Margin="0,3,0,0"
                                                   Foreground="{StaticResource Ronin.CyanBright}"/>
                                        <TextBlock Text="{Binding SelectedNode.ChildCountText}"
                                                   FontSize="11" Margin="0,1,0,3"
                                                   Foreground="{StaticResource Ronin.TextMid}"
                                                   Visibility="{Binding SelectedNode.IsDirectory, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding SelectedNode.FullPath}"
                                                   FontSize="10" TextWrapping="Wrap"
                                                   Foreground="{StaticResource Ronin.CyanDim}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Quick actions row -->
                                <DockPanel Margin="0,6,0,0">
                                    <Button DockPanel.Dock="Left"
                                            Content="🗂  Explorer"
                                            Command="{Binding OpenInExplorerCommand}"
                                            FontSize="11" Height="26" Padding="8,0"
                                            ToolTip="Open containing folder in Windows Explorer (Ctrl+E)"/>
                                    <Button DockPanel.Dock="Left"
                                            Content="📋  Copy Path"
                                            Command="{Binding CopyPathCommand}"
                                            FontSize="11" Height="26" Padding="8,0"
                                            Margin="6,0,0,0"
                                            ToolTip="Copy full path to clipboard (Ctrl+Shift+C)"/>
                                    <Button DockPanel.Dock="Left"
                                            Content="💻  Terminal"
                                            Command="{Binding OpenTerminalCommand}"
                                            FontSize="11" Height="26" Padding="8,0"
                                            Margin="6,0,0,0"
                                            ToolTip="Open a terminal at this location"/>
                                </DockPanel>

                                <Separator Margin="0,12,0,0"
                                           Background="{StaticResource Ronin.Border}"/>

                                <!-- Move / Delete toggle -->
                                <TextBlock Text="ACTION" Style="{StaticResource SectionLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="  Move  "
                                                 IsChecked="{Binding IsMoveMode}"
                                                 Command="{Binding SetMoveModeCommand}"
                                                 Style="{DynamicResource MahApps.Styles.ToggleButton}"
                                                 GroupName="ActionGroup"
                                                 ToolTip="Move selected item to a destination"/>
                                    <RadioButton Content="  Copy  "
                                                 IsChecked="{Binding IsCopyMode}"
                                                 Command="{Binding SetCopyModeCommand}"
                                                 Style="{DynamicResource MahApps.Styles.ToggleButton}"
                                                 GroupName="ActionGroup"
                                                 ToolTip="Copy selected item to a destination"
                                                 Margin="8,0,0,0"/>
                                    <RadioButton Content="  Delete  "
                                                 IsChecked="{Binding IsDeleteMode}"
                                                 Command="{Binding SetDeleteModeCommand}"
                                                 Style="{DynamicResource MahApps.Styles.ToggleButton}"
                                                 GroupName="ActionGroup"
                                                 ToolTip="Delete selected item"
                                                 Margin="8,0,0,0"/>
                                </StackPanel>

                                <!-- ──────────────────────────────────── MOVE PANEL -->
                                <StackPanel Visibility="{Binding IsMoveMode, Converter={StaticResource BoolToVis}}">

                                    <TextBlock Text="DESTINATION" Style="{StaticResource SectionLabel}"/>
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Content="…" Width="34" Margin="4,0,0,0"
                                                Command="{Binding BrowseDestinationCommand}"
                                                ToolTip="Browse for destination folder"/>
                                        <TextBox Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}"
                                                 mah:TextBoxHelper.Watermark="e.g.  E:\Backup"
                                                 Background="#141414" Foreground="#D0D0D0"
                                                 BorderBrush="{StaticResource Ronin.Border}"
                                                 CaretBrush="{StaticResource Ronin.Cyan}"/>
                                    </DockPanel>

                                    <TextBlock Text="FLAGS" Style="{StaticResource SectionLabel}"/>
                                    <CheckBox Content="Force (overwrite existing files)"
                                              IsChecked="{Binding MoveForce}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Overwrites existing and read-only files without prompting."/>
                                    <CheckBox Content="WhatIf  (dry run, no changes made)"
                                              IsChecked="{Binding MoveWhatIf}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Simulates the move and prints what would happen, without making any changes."/>
                                    <CheckBox Content="Verbose (log each moved item)"
                                              IsChecked="{Binding MoveVerbose}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Outputs a line to the console for each file or folder that is moved."/>
                                    <CheckBox Content="NeverOverwrite (abort if destination exists)"
                                              IsChecked="{Binding MoveNeverOverwrite}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Aborts before starting if the destination already exists."/>
                                    <CheckBox Content="LiteralPath (treat [ and ] as literal)"
                                              IsChecked="{Binding MoveLiteralPath}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Treats special characters like [ and ] as literal text instead of wildcards."/>

                                    <TextBlock Text="FILTER  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding MoveFilter, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.txt"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"
                                             ToolTip="Fast provider-level filter. Only one pattern allowed."/>
                                    <TextBlock Text="INCLUDE  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding MoveInclude, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.png, *.jpg"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"
                                             ToolTip="Comma-separated patterns to include. Supports wildcards."/>
                                    <TextBlock Text="EXCLUDE  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding MoveExclude, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.tmp, *.log"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"
                                             ToolTip="Comma-separated patterns to exclude. Supports wildcards."/>
                                </StackPanel>

                                <!-- ──────────────────────────────────── COPY PANEL -->
                                <StackPanel Visibility="{Binding IsCopyMode, Converter={StaticResource BoolToVis}}">

                                    <TextBlock Text="DESTINATION" Style="{StaticResource SectionLabel}"/>
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Content="…" Width="34" Margin="4,0,0,0"
                                                Command="{Binding BrowseDestinationCommand}"
                                                ToolTip="Browse for destination folder"/>
                                        <TextBox Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}"
                                                 mah:TextBoxHelper.Watermark="e.g.  E:\Backup"
                                                 Background="#141414" Foreground="#D0D0D0"
                                                 BorderBrush="{StaticResource Ronin.Border}"
                                                 CaretBrush="{StaticResource Ronin.Cyan}"/>
                                    </DockPanel>

                                    <TextBlock Text="FLAGS" Style="{StaticResource SectionLabel}"/>
                                    <CheckBox Content="Recurse (copy folder contents)"
                                              IsChecked="{Binding CopyRecurse}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Copies all files and subdirectories inside the selected folder. Required to copy a folder tree."/>
                                    <CheckBox Content="Force (overwrite existing files)"
                                              IsChecked="{Binding CopyForce}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Overwrites existing and read-only files at the destination without prompting."/>
                                    <CheckBox Content="WhatIf  (dry run, no changes made)"
                                              IsChecked="{Binding CopyWhatIf}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Simulates the copy and prints what would happen, without making any changes."/>
                                    <CheckBox Content="Verbose (log each copied item)"
                                              IsChecked="{Binding CopyVerbose}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Outputs a line to the console for each file or folder that is copied."/>
                                    <CheckBox Content="LiteralPath (treat [ and ] as literal)"
                                              IsChecked="{Binding CopyLiteralPath}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Treats special characters like [ and ] as literal text instead of wildcards."/>

                                    <TextBlock Text="FILTER  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding CopyFilter, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.txt"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"
                                             ToolTip="Fast provider-level filter. Only one pattern allowed."/>
                                    <TextBlock Text="INCLUDE  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding CopyInclude, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.png, *.jpg"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"
                                             ToolTip="Comma-separated patterns to include. Supports wildcards."/>
                                    <TextBlock Text="EXCLUDE  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding CopyExclude, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.tmp, *.log"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"
                                             ToolTip="Comma-separated patterns to exclude. Supports wildcards."/>
                                </StackPanel>

                                <!-- ────────────────────────────────── DELETE PANEL -->
                                <StackPanel Visibility="{Binding IsDeleteMode, Converter={StaticResource BoolToVis}}">

                                    <TextBlock Text="MODE" Style="{StaticResource SectionLabel}"/>
                                    <CheckBox Content="Send to Recycle Bin (recommended)"
                                              IsChecked="{Binding DeleteToRecycleBin}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="When ticked, the item goes to the Recycle Bin and can be restored. Untick to delete permanently with the flags below."/>

                                    <!-- Permanent-delete options (only relevant when not recycling) -->
                                    <StackPanel Visibility="{Binding DeleteToRecycleBin, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="FLAGS" Style="{StaticResource SectionLabel}"/>
                                    <CheckBox Content="Force (remove read-only and hidden items)"
                                              IsChecked="{Binding DeleteForce}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Removes read-only and hidden items without prompting."/>
                                    <CheckBox Content="Recurse  (delete folder contents)"
                                              IsChecked="{Binding DeleteRecurse}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Deletes all files and subdirectories inside the selected folder recursively."/>
                                    <CheckBox Content="WhatIf  (dry run, no changes made)"
                                              IsChecked="{Binding DeleteWhatIf}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Simulates the delete and prints what would happen, without removing anything."/>
                                    <CheckBox Content="Verbose (log each deleted item)"
                                              IsChecked="{Binding DeleteVerbose}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Outputs a line to the console for each file or folder that is deleted."/>
                                    <CheckBox Content="LiteralPath (treat [ and ] as literal)"
                                              IsChecked="{Binding DeleteLiteralPath}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Treats special characters like [ and ] as literal text instead of wildcards."/>

                                    <TextBlock Text="FILTER  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding DeleteFilter, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.txt"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"/>
                                    <TextBlock Text="INCLUDE  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding DeleteInclude, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.tmp"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"/>
                                    <TextBlock Text="EXCLUDE  (optional)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding DeleteExclude, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.important"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"/>

                                    <Border Background="#1C0505" CornerRadius="4"
                                            BorderBrush="#5A0A0A" BorderThickness="1"
                                            Margin="0,12,0,0" Padding="10,8">
                                        <TextBlock Text="⚠  This operation is permanent and cannot be undone."
                                                   Foreground="#E04040"
                                                   TextWrapping="Wrap" FontSize="12"/>
                                    </Border>
                                    </StackPanel>
                                    <!-- end permanent-delete options -->
                                </StackPanel>

                                <!-- Command preview -->
                                <TextBlock Text="COMMAND PREVIEW" Style="{StaticResource SectionLabel}" Margin="0,14,0,5"/>
                                <Border Background="#060606"
                                        BorderBrush="{StaticResource Ronin.BorderSubtle}"
                                        BorderThickness="1" CornerRadius="3"
                                        Padding="8,6">
                                    <TextBox Text="{Binding CommandPreview, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             Foreground="{StaticResource Ronin.Cyan}"
                                             BorderThickness="0"
                                             FontFamily="Consolas" FontSize="11"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MaxHeight="90"/>
                                </Border>

                                <!-- Execute button -->
                                <Button Content="{Binding ExecuteButtonText}"
                                        Command="{Binding ExecuteActionCommand}"
                                        Height="38" Margin="0,16,0,0"
                                        FontSize="13"
                                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════════════════════ TAB: TOOLS -->
                <TabItem Header="Tools">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource Ronin.PanelBg}">
                        <StackPanel Margin="12,10,12,14">

                            <!-- Admin note -->
                            <Border Background="#0D0D0D"
                                    BorderBrush="{StaticResource Ronin.BorderSubtle}"
                                    BorderThickness="1" CornerRadius="3"
                                    Padding="9,6" Margin="0,0,0,10">
                                <TextBlock FontSize="10" TextWrapping="Wrap"
                                           Foreground="{StaticResource Ronin.TextMid}">
                                    <Run Text="⚡"/>
                                    <Run Text=" Commands run in the existing PowerShell session. Most require Administrator. Launch as Admin if output shows access errors."/>
                                </TextBlock>
                            </Border>

                            <!-- ══ DISK HEALTH ════════════════════════════════ -->
                            <Expander IsExpanded="True" Margin="0,0,0,6">
                                <Expander.Header>
                                    <TextBlock Text="💽   DISK HEALTH"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Ronin.TextBright}"/>
                                </Expander.Header>
                                <StackPanel Margin="4,6,0,4">

                                    <TextBlock Text="Drive" Style="{StaticResource SectionLabel}" Margin="0,4,0,4"/>
                                    <ComboBox ItemsSource="{Binding AvailableDrives}"
                                              SelectedItem="{Binding ChkdskDrive}"
                                              Background="#141414" Foreground="#D0D0D0"
                                              BorderBrush="{StaticResource Ronin.TextBright}"
                                              ToolTip="Select the drive to check. Only mounted, ready drives are listed."/>

                                    <TextBlock Text="FLAGS" Style="{StaticResource SectionLabel}"/>
                                    <CheckBox Content="Fix errors  (/f)"
                                              IsChecked="{Binding ChkdskFixErrors}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Automatically fix file system errors found during the scan. On the system drive this schedules the check for next restart."/>
                                    <CheckBox Content="Locate bad sectors  (/r, implies /f)"
                                              IsChecked="{Binding ChkdskBadSectors}"
                                              Style="{StaticResource FlagCheck}"
                                              ToolTip="Scans every sector and attempts to recover readable data from bad sectors. Significantly longer than /f alone. Also schedules on next restart for the system drive."/>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="▶  Run CHKDSK"
                                                Command="{Binding RunChkdskCommand}"
                                                Height="28" FontSize="11"
                                                ToolTip="Run CHKDSK with the selected drive and flags. Outputs results to the console below."/>
                                        <Button Grid.Column="2"
                                                Content="▶  Read-Only Scan"
                                                Command="{Binding RunChkdskReadOnlyCommand}"
                                                Height="28" FontSize="11"
                                                ToolTip="Scans the selected drive for errors without fixing them or requiring a restart. Safe to run on any drive at any time."/>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <Separator Background="{StaticResource Ronin.BorderSubtle}" Margin="0,2,0,6"/>

                            <!-- ══ SYSTEM INTEGRITY ═══════════════════════════ -->
                            <Expander IsExpanded="True" Margin="0,0,0,6">
                                <Expander.Header>
                                    <TextBlock Text="🔧   SYSTEM INTEGRITY  (SFC)"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Ronin.TextBright}"/>
                                </Expander.Header>
                                <StackPanel Margin="4,6,0,4">
                                    <TextBlock Text="System File Checker scans and repairs protected Windows files."
                                               FontSize="10" Foreground="{StaticResource Ronin.TextMid}"
                                               TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <Button Content="▶  Scan &amp; Repair  (sfc /scannow)"
                                            Command="{Binding RunSfcScanCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            ToolTip="Scans all protected system files and replaces corrupted or missing ones with cached copies from %WinDir%\System32\dllcache. Requires Administrator. Output is also written to C:\Windows\Logs\CBS\CBS.log."/>
                                    <Button Content="▶  Verify Only  (sfc /verifyonly)"
                                            Command="{Binding RunSfcVerifyCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            ToolTip="Scans all protected system files for integrity violations but makes no repairs. Useful for diagnosing issues without changing anything."/>
                                </StackPanel>
                            </Expander>

                            <Separator Background="{StaticResource Ronin.BorderSubtle}" Margin="0,2,0,6"/>

                            <!-- ══ DISM ════════════════════════════════════════ -->
                            <Expander IsExpanded="False" Margin="0,0,0,6">
                                <Expander.Header>
                                    <TextBlock Text="🪟   WINDOWS IMAGE  (DISM)"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Ronin.TextBright}"/>
                                </Expander.Header>
                                <StackPanel Margin="4,6,0,4">
                                    <TextBlock FontSize="10" Foreground="{StaticResource Ronin.TextMid}"
                                               TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="DISM repairs the Windows component store. Run CheckHealth first, then ScanHealth, then RestoreHealth only if needed."/>

                                    <Button Content="▶  Check Health"
                                            Command="{Binding RunDismCheckCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            ToolTip="Reads the component store's flag file to quickly determine if a corruption has been detected. Takes only a few seconds and makes no changes."/>
                                    <Button Content="▶  Scan Health"
                                            Command="{Binding RunDismScanCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            ToolTip="Fully scans the component store for corruption. Takes several minutes. Makes no repairs. Run RestoreHealth to fix anything found."/>

                                    <TextBlock Text="RESTORE SOURCE  (optional)"
                                               Style="{StaticResource SectionLabel}"/>
                                    <TextBlock FontSize="10" Foreground="{StaticResource Ronin.TextMid}"
                                               TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="Leave blank to use Windows Update. Point to a mounted ISO or WIM to repair offline."/>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="…" Width="30" Margin="4,0,0,0"
                                                Command="{Binding BrowseDismSourceCommand}"
                                                ToolTip="Browse to a folder containing a WIM or ESD repair source (e.g. a mounted Windows ISO at D:\Sources\install.wim)."/>
                                        <TextBox Text="{Binding DismSource, UpdateSourceTrigger=PropertyChanged}"
                                                 mah:TextBoxHelper.Watermark="e.g.  D:\Sources\install.wim"
                                                 Background="#141414" Foreground="#D0D0D0"
                                                 BorderBrush="{StaticResource Ronin.Border}"
                                                 ToolTip="Optional repair source. Leave blank to download from Windows Update."/>
                                    </DockPanel>

                                    <Button Content="▶  Restore Health"
                                            Command="{Binding RunDismRestoreCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,8,0,3"
                                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                                            ToolTip="Repairs component store corruption using Windows Update or the specified source. Can take 10–20 minutes. The system remains usable during the repair."/>

                                    <Separator Background="{StaticResource Ronin.BorderSubtle}" Margin="0,8,0,6"/>

                                    <Border Background="#1C0505" CornerRadius="3"
                                            BorderBrush="#5A0A0A" BorderThickness="1"
                                            Padding="8,6" Margin="0,0,0,6">
                                        <TextBlock FontSize="10" Foreground="#E04040" TextWrapping="Wrap"
                                                   Text="⚠  Component Cleanup permanently removes old update backups. You will not be able to uninstall those updates afterward."/>
                                    </Border>
                                    <Button Content="⚠  Cleanup Components"
                                            Command="{Binding RunDismCleanupCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,0,0,3"
                                            Foreground="#E06020"
                                            ToolTip="Runs DISM /StartComponentCleanup /ResetBase to shrink the WinSxS folder by permanently removing superseded update backups. A confirmation dialog will appear."/>
                                </StackPanel>
                            </Expander>

                            <Separator Background="{StaticResource Ronin.BorderSubtle}" Margin="0,2,0,6"/>

                            <!-- ══ NETWORK ═════════════════════════════════════ -->
                            <Expander IsExpanded="False" Margin="0,0,0,6">
                                <Expander.Header>
                                    <TextBlock Text="🌐   NETWORK"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Ronin.TextBright}"/>
                                </Expander.Header>
                                <StackPanel Margin="4,6,0,4">

                                    <Button Content="▶  Flush DNS Cache"
                                            Command="{Binding RunFlushDnsCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            ToolTip="Clears the local DNS resolver cache (ipconfig /flushdns). Useful after changing DNS settings or fixing name resolution errors. Takes effect immediately with no reboot."/>
                                    <Button Content="▶  Release &amp; Renew IP"
                                            Command="{Binding RunRenewIpCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            ToolTip="Releases the current DHCP IP lease then requests a new one (ipconfig /release then /renew). Useful when the network adapter gets stuck with an incorrect or duplicate address."/>

                                    <Separator Background="{StaticResource Ronin.BorderSubtle}" Margin="0,6,0,6"/>

                                    <Border Background="#1C0505" CornerRadius="3"
                                            BorderBrush="#5A0A0A" BorderThickness="1"
                                            Padding="8,6" Margin="0,0,0,6">
                                        <TextBlock FontSize="10" Foreground="#E04040" TextWrapping="Wrap"
                                                   Text="⚠  The following commands require a reboot to take effect."/>
                                    </Border>
                                    <Button Content="⚠  Reset Winsock"
                                            Command="{Binding RunWinsockResetCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            Foreground="#E06020"
                                            ToolTip="Resets the Winsock catalog to a clean state (netsh winsock reset). Fixes connectivity issues caused by corrupted LSP entries or malware. Requires reboot."/>
                                    <Button Content="⚠  Reset TCP/IP Stack"
                                            Command="{Binding RunTcpIpResetCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            Foreground="#E06020"
                                            ToolTip="Resets the TCP/IP stack to default settings (netsh int ip reset). Use this as a last resort when other network fixes have not worked. Requires reboot."/>
                                </StackPanel>
                            </Expander>

                            <Separator Background="{StaticResource Ronin.BorderSubtle}" Margin="0,2,0,6"/>

                            <!-- ══ MAINTENANCE ════════════════════════════════ -->
                            <Expander IsExpanded="False" Margin="0,0,0,6">
                                <Expander.Header>
                                    <TextBlock Text="🧰   MAINTENANCE"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Ronin.TextBright}"/>
                                </Expander.Header>
                                <StackPanel Margin="4,6,0,4">

                                    <Button Content="▶  Disk Cleanup"
                                            Command="{Binding RunDiskCleanupCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            ToolTip="Opens the Windows Disk Cleanup utility (cleanmgr.exe). Select which file types to remove in the dialog that appears."/>

                                    <Separator Background="{StaticResource Ronin.BorderSubtle}" Margin="0,6,0,6"/>

                                    <Border Background="#1C0505" CornerRadius="3"
                                            BorderBrush="#5A0A0A" BorderThickness="1"
                                            Padding="8,6" Margin="0,0,0,6">
                                        <TextBlock FontSize="10" Foreground="#E04040" TextWrapping="Wrap"
                                                   Text="⚠  Memory Diagnostic requires an immediate system restart. Save all work before running."/>
                                    </Border>
                                    <Button Content="⚠  Memory Diagnostic"
                                            Command="{Binding RunMemoryDiagCommand}"
                                            HorizontalAlignment="Stretch" Height="28" FontSize="11"
                                            Margin="0,3,0,3"
                                            Foreground="#E06020"
                                            ToolTip="Schedules a Windows Memory Diagnostic test (mdsched.exe) and restarts your computer to scan RAM for errors. Results are shown after Windows restarts."/>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════════════════════════════════ TAB: CLEANUP -->
                <TabItem Header="Cleanup">
                    <Grid Background="{StaticResource Ronin.PanelBg}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="12,10,12,6">
                            <TextBlock FontSize="10" TextWrapping="Wrap"
                                       Foreground="{StaticResource Ronin.TextMid}" Margin="0,0,0,8"
                                       Text="Remove old files by rule (e.g. logs older than 30 days). Preview first, then Apply. Deletes go to the Recycle Bin by default."/>

                            <TextBlock Text="FOLDER" Style="{StaticResource SectionLabel}"/>
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right" Content="…" Width="34" Margin="4,0,0,0"
                                        Command="{Binding BrowseCleanupFolderCommand}"
                                        ToolTip="Browse for the folder to clean"/>
                                <TextBox Text="{Binding CleanupFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#141414" Foreground="#D0D0D0"
                                         BorderBrush="{StaticResource Ronin.Border}"/>
                            </DockPanel>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PATTERN" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Text="{Binding CleanupPattern, UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Watermark="e.g. *.log"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="OLDER THAN (DAYS)" Style="{StaticResource SectionLabel}"/>
                                    <TextBox Width="80"
                                             Text="{Binding CleanupOlderThanDays, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#141414" Foreground="#D0D0D0"
                                             BorderBrush="{StaticResource Ronin.Border}"
                                             HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Include subfolders (recurse)"
                                      IsChecked="{Binding CleanupRecurse}"
                                      Style="{StaticResource FlagCheck}" Margin="0,8,0,0"/>
                            <CheckBox Content="Send to Recycle Bin (recommended)"
                                      IsChecked="{Binding CleanupRecycle}"
                                      Style="{StaticResource FlagCheck}"
                                      ToolTip="Untick to delete matched files permanently."/>

                            <DockPanel Margin="0,8,0,0" LastChildFill="True">
                                <Button DockPanel.Dock="Left" Content="🔍  Preview"
                                        Command="{Binding PreviewCleanupCommand}"
                                        IsEnabled="{Binding IsCleaning, Converter={StaticResource InvBool}}"
                                        Height="28" FontSize="11" Padding="10,0"/>
                                <Button DockPanel.Dock="Left" Content="✖"
                                        Command="{Binding CancelCleanupCommand}"
                                        IsEnabled="{Binding IsCleaning}"
                                        Width="30" Height="28" Margin="6,0,0,0"
                                        ToolTip="Cancel"/>
                                <TextBlock Text="{Binding CleanupStatus}"
                                           VerticalAlignment="Center" FontSize="10"
                                           Foreground="{StaticResource Ronin.CyanDim}"
                                           Margin="10,0,0,0" TextWrapping="Wrap"/>
                            </DockPanel>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding CleanupResults}"
                                  IsReadOnly="True" AutoGenerateColumns="False"
                                  Background="#080808" Foreground="#C8C8C8" BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource Ronin.BorderSubtle}"
                                  RowBackground="#080808" AlternatingRowBackground="#0D0D0D"
                                  ColumnHeaderHeight="24" FontSize="11" SelectionMode="Single"
                                  Margin="12,0,12,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"     Binding="{Binding Name}"        Width="*"/>
                                <DataGridTextColumn Header="Size"     Binding="{Binding SizeDisplay}"  Width="70"/>
                                <DataGridTextColumn Header="Modified" Binding="{Binding DateModified, StringFormat='{}{0:yyyy-MM-dd}'}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Margin="12,6,12,12">
                            <Border Background="#1C0505" CornerRadius="3"
                                    BorderBrush="#5A0A0A" BorderThickness="1"
                                    Padding="8,6" Margin="0,0,0,6"
                                    Visibility="{Binding CleanupRecycle, Converter={StaticResource InvBoolToVis}}">
                                <TextBlock FontSize="10" Foreground="#E04040" TextWrapping="Wrap"
                                           Text="⚠  Permanent delete is enabled. Matched files will not go to the Recycle Bin."/>
                            </Border>
                            <Button Content="▶   Apply Cleanup"
                                    Command="{Binding ApplyCleanupCommand}"
                                    IsEnabled="{Binding IsCleaning, Converter={StaticResource InvBool}}"
                                    Height="34" FontSize="12"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ══════════════════════════════════════════════ STATUS BAR -->
        <Border Grid.Row="2"
                Background="#0A0A0A"
                BorderBrush="{StaticResource Ronin.BorderSubtle}"
                BorderThickness="0,1,0,1"
                Padding="12,4">
            <DockPanel LastChildFill="True">
                <!-- Keyboard shortcut hints on the right -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                  <TextBlock Text="Ctrl+E  Explorer"
                               FontSize="10" Foreground="{StaticResource Ronin.TextDim}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Ctrl+Shift+C  Copy Path"
                               FontSize="10" Foreground="{StaticResource Ronin.TextDim}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Scan progress (visible only while an operation runs) -->
                <ProgressBar DockPanel.Dock="Right"
                             Width="150" Height="12" Margin="12,0,12,0"
                             Minimum="0" Maximum="100"
                             Value="{Binding ScanProgress}"
                             IsIndeterminate="{Binding ScanIndeterminate}"
                             Foreground="{StaticResource Ronin.Cyan}"
                             Background="#141414"
                             BorderBrush="{StaticResource Ronin.Border}"
                             Visibility="{Binding IsOperationRunning, Converter={StaticResource BoolToVis}}"/>
                <!-- Main status info -->
                <TextBlock Text="{Binding StatusBarText}"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="{StaticResource Ronin.TextBright}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════ HORIZONTAL SPLITTER -->
        <GridSplitter Grid.Row="3"
                      HorizontalAlignment="Stretch">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Background" Value="{StaticResource Ronin.Border}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Ronin.BorderHover}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <!-- ══════════════════════════════════════════════════ CONSOLE -->
        <Border Grid.Row="4"
                Background="{StaticResource Ronin.ConsoleBg}"
                BorderBrush="{StaticResource Ronin.Border}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="OUTPUT"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource Ronin.Orange}"
                           Margin="10,5,0,2"/>

                <TextBox Grid.Row="1"
                         x:Name="ConsoleBox"
                         Text="{Binding ConsoleText, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="{StaticResource Ronin.Cyan}"
                         FontFamily="Consolas" FontSize="12"
                         BorderThickness="0"
                         Padding="10,0,10,8"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="ConsoleBox_TextChanged"/>
            </Grid>
        </Border>

    </Grid>
</mah:MetroWindow>
